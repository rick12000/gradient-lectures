---
import MobileMenuFooter from '@astrojs/starlight/components/MobileMenuFooter.astro';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';

const { sidebar } = Astro.locals.starlightRoute;

// Recursive function to check if a group contains the current page
function hasCurrent(entry: any) {
  if (entry.isCurrent) return true;
  if (entry.type === 'group' && entry.entries) {
    return entry.entries.some(hasCurrent);
  }
  return false;
}

// Find the active group (the track that contains the current page)
let activeGroup = sidebar.find(hasCurrent);

// If we found an active group, we only show its children (the track index)
let sublistToRender = sidebar;
if (activeGroup && activeGroup.entries) {
  sublistToRender = activeGroup.entries;
}
---

<div class="sidebar-header-custom">
  <div class="sidebar-title">Track Content</div>
  <button class="sidebar-toggle-arrow left-sidebar-toggle" title="Toggle Sidebar">
    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
      <line x1="9" y1="3" x2="9" y2="21"></line>
    </svg>
  </button>
</div>

{activeGroup && (
  <div class="track-highlight-label">
    <span class="track-prefix">Track:</span> <span class="track-name">{activeGroup.label}</span>
  </div>
)}

<div class="track-highlight-wrapper">
  <SidebarPersister>
    <SidebarSublist sublist={sublistToRender} />
  </SidebarPersister>
</div>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>

<style>
  .sidebar-header-custom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .sidebar-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gl-muted);
  }

  .track-highlight-label {
    margin-bottom: 1.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--gl-accent-bg);
    border-left: 3px solid var(--sl-color-accent);
    border-radius: 0 4px 4px 0;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .track-prefix {
    font-weight: 600;
    color: var(--sl-color-text);
  }

  .track-name {
    font-weight: 700;
    color: var(--sl-color-accent);
  }

  .sidebar-toggle-arrow {
    background: transparent;
    border: none;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, background-color 0.2s, transform 0.3s ease;
  }

  .sidebar-toggle-arrow:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }

  /* When sidebar is collapsed, the arrow should point right. 
     We'll handle the rotation via global CSS based on body class */
  :global(body.hide-left-sidebar) .left-sidebar-toggle svg {
    /* No rotation needed for the sidebar icon */
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const leftToggles = document.querySelectorAll('.left-sidebar-toggle');
    leftToggles.forEach(btn => {
      btn.addEventListener('click', () => {
        document.body.classList.toggle('hide-left-sidebar');
      });
    });
  });
</script>