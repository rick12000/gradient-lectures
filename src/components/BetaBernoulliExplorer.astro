---
// BetaBernoulliExplorer — interactive Beta-Bernoulli conjugate model
---

<div class="interactive-chart" id="beta-explorer">
  <div class="interactive-chart__header">Interactive — Beta-Bernoulli Explorer</div>
  <div class="interactive-chart__canvas">
    <svg id="beta-svg" width="100%" viewBox="0 0 700 320" preserveAspectRatio="xMidYMid meet" aria-label="Beta distribution plot"></svg>
    <div id="beta-stats" class="chart-stats-row"></div>
  </div>
  <div class="interactive-chart__controls">
    <div class="chart-control">
      <label for="alpha-prior">Prior α <span class="control-value" id="alpha-val">2</span></label>
      <input type="range" id="alpha-prior" min="1" max="20" step="0.5" value="2" />
    </div>
    <div class="chart-control">
      <label for="beta-prior">Prior β <span class="control-value" id="beta-val">2</span></label>
      <input type="range" id="beta-prior" min="1" max="20" step="0.5" value="2" />
    </div>
    <div class="chart-control">
      <label for="heads-obs">Observed Heads <span class="control-value" id="heads-val">7</span></label>
      <input type="range" id="heads-obs" min="0" max="50" step="1" value="7" />
    </div>
    <div class="chart-control">
      <label for="tails-obs">Observed Tails <span class="control-value" id="tails-val">3</span></label>
      <input type="range" id="tails-obs" min="0" max="50" step="1" value="3" />
    </div>
  </div>
</div>

<script>
(function() {
  "use strict";

  function logGamma(z) {
    const g = 7;
    const C = [
      0.99999999999980993, 676.5203681218851, -1259.1392167224028,
      771.32342877765313, -176.61502916214059, 12.507343278686905,
      -0.13857109526572012, 9.9843695780195716e-6, 1.5056327351493116e-7,
    ];
    if (z < 0.5) return Math.log(Math.PI) - Math.log(Math.sin(Math.PI * z)) - logGamma(1 - z);
    z -= 1;
    let x = C[0];
    for (let i = 1; i < g + 2; i++) x += C[i] / (z + i);
    const t = z + g + 0.5;
    return 0.5 * Math.log(2 * Math.PI) + (z + 0.5) * Math.log(t) - t + Math.log(x);
  }

  function logBeta(a, b) { return logGamma(a) + logGamma(b) - logGamma(a + b); }

  function betaPDF(x, a, b) {
    if (x <= 0 || x >= 1) return 0;
    return Math.exp((a - 1) * Math.log(x) + (b - 1) * Math.log(1 - x) - logBeta(a, b));
  }

  function betaMean(a, b) { return a / (a + b); }
  function betaMode(a, b) { return (a > 1 && b > 1) ? (a - 1) / (a + b - 2) : null; }
  function betaVariance(a, b) { return (a * b) / ((a + b) * (a + b) * (a + b + 1)); }

  function betaIncomplete(x, a, b) {
    if (x <= 0) return 0;
    if (x >= 1) return 1;
    const lbeta = logBeta(a, b);
    const front = Math.exp(Math.log(x) * a + Math.log(1 - x) * b - lbeta) / a;
    let f = 1, C2 = 1, D = 1 - (a + b) * x / (a + 1);
    if (Math.abs(D) < 1e-30) D = 1e-30;
    D = 1 / D; f = D;
    for (let m = 1; m <= 200; m++) {
      const m2 = 2 * m;
      let num = m * (b - m) * x / ((a + m2 - 1) * (a + m2));
      D = 1 + num * D; if (Math.abs(D) < 1e-30) D = 1e-30; D = 1 / D;
      C2 = 1 + num / C2; if (Math.abs(C2) < 1e-30) C2 = 1e-30;
      f *= C2 * D;
      num = -(a + m) * (a + b + m) * x / ((a + m2) * (a + m2 + 1));
      D = 1 + num * D; if (Math.abs(D) < 1e-30) D = 1e-30; D = 1 / D;
      C2 = 1 + num / C2; if (Math.abs(C2) < 1e-30) C2 = 1e-30;
      f *= C2 * D;
      if (Math.abs(C2 * D - 1) < 1e-10) break;
    }
    const result = front * f;
    return x < (a + 1) / (a + b + 2) ? result : 1 - betaIncomplete(1 - x, b, a);
  }

  function betaQuantile(p, a, b, tol = 1e-8) {
    let lo = 0, hi = 1;
    for (let i = 0; i < 200; i++) {
      const mid = (lo + hi) / 2;
      if (betaIncomplete(mid, a, b) < p) lo = mid; else hi = mid;
      if (hi - lo < tol) break;
    }
    return (lo + hi) / 2;
  }

  const svg = document.getElementById('beta-svg');
  const statsDiv = document.getElementById('beta-stats');
  const margin = { top: 20, right: 20, bottom: 40, left: 44 };
  const W = 700, H = 320;
  const iW = W - margin.left - margin.right;
  const iH = H - margin.top - margin.bottom;
  const N_POINTS = 300;

  const xs = Array.from({ length: N_POINTS }, (_, i) => 0.001 + (0.998) * i / (N_POINTS - 1));

  function xScale(v) { return margin.left + v * iW; }
  function yScale(v, yMax) { return margin.top + iH - (v / yMax) * iH; }

  function makePath(ys, yMax, color, sw, fillOpacity) {
    const pts = xs.map((x, i) => `${xScale(x).toFixed(2)},${yScale(ys[i], yMax).toFixed(2)}`).join(' L ');
    const bottom = yScale(0, yMax).toFixed(2);
    const area = `<path d="M ${xScale(xs[0]).toFixed(2)},${bottom} L ${pts} L ${xScale(xs[xs.length - 1]).toFixed(2)},${bottom} Z" fill="${color}" fill-opacity="${fillOpacity}" stroke="none"/>`;
    const line = `<path d="M ${pts}" stroke="${color}" stroke-width="${sw}" fill="none" vector-effect="non-scaling-stroke"/>`;
    return area + line;
  }

  function makeCI(a, b, yMax, color) {
    const lo = betaQuantile(0.025, a, b);
    const hi = betaQuantile(0.975, a, b);
    const ciXs = xs.filter(x => x >= lo && x <= hi);
    if (ciXs.length < 2) return '';
    const ciYs = ciXs.map(x => betaPDF(x, a, b));
    const pts = ciXs.map((x, i) => `${xScale(x).toFixed(2)},${yScale(ciYs[i], yMax).toFixed(2)}`).join(' L ');
    const bottom = yScale(0, yMax).toFixed(2);
    return `<path d="M ${xScale(ciXs[0]).toFixed(2)},${bottom} L ${pts} L ${xScale(ciXs[ciXs.length - 1]).toFixed(2)},${bottom} Z" fill="${color}" fill-opacity="0.22" stroke="none"/>`;
  }

  function render() {
    const alpha0 = parseFloat(document.getElementById('alpha-prior').value);
    const beta0 = parseFloat(document.getElementById('beta-prior').value);
    const h = parseInt(document.getElementById('heads-obs').value);
    const t = parseInt(document.getElementById('tails-obs').value);

    const alphaN = alpha0 + h;
    const betaN = beta0 + t;

    const priorY = xs.map(x => betaPDF(x, alpha0, beta0));
    const postY = xs.map(x => betaPDF(x, alphaN, betaN));
    const likeY = xs.map(x =>
      h === 0 && t === 0 ? 1 : Math.exp(h * Math.log(x + 1e-12) + t * Math.log(1 - x + 1e-12))
    );

    const likeMax = Math.max(...likeY);
    const yMaxRaw = Math.max(...priorY, ...postY);
    const yMax = yMaxRaw * 1.1;
    const likeYScaled = likeY.map(v => (v / likeMax) * yMax * 0.82);

    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const textColor = isDark ? '#a1a1aa' : '#71717a';
    const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
    const axisColor = isDark ? '#262626' : '#e4e4e7';
    const postColor = isDark ? '#818cf8' : '#6366f1';
    const priorColor = isDark ? '#64748b' : '#94a3b8';

    const colors = { prior: priorColor, like: '#f59e0b', post: postColor };

    const xTicks = [0, 0.25, 0.5, 0.75, 1.0];
    const xTicksSVG = xTicks.map(v =>
      `<line x1="${xScale(v).toFixed(1)}" y1="${(margin.top + iH).toFixed(1)}" x2="${xScale(v).toFixed(1)}" y2="${(margin.top + iH + 5).toFixed(1)}" stroke="${axisColor}"/>` +
      `<text x="${xScale(v).toFixed(1)}" y="${(margin.top + iH + 18).toFixed(1)}" text-anchor="middle" font-size="11" fill="${textColor}">${v}</text>` +
      `<line x1="${xScale(v).toFixed(1)}" y1="${margin.top}" x2="${xScale(v).toFixed(1)}" y2="${(margin.top + iH).toFixed(1)}" stroke="${gridColor}" stroke-dasharray="3,3"/>`
    ).join('');

    const xAxis = `<line x1="${margin.left}" y1="${margin.top + iH}" x2="${margin.left + iW}" y2="${margin.top + iH}" stroke="${axisColor}" stroke-width="1.5"/>`;
    const yAxis = `<line x1="${margin.left}" y1="${margin.top}" x2="${margin.left}" y2="${margin.top + iH}" stroke="${axisColor}" stroke-width="1.5"/>`;
    const yLabel = `<text x="${(margin.left - 36).toFixed(1)}" y="${(margin.top + iH / 2).toFixed(1)}" text-anchor="middle" transform="rotate(-90,${(margin.left - 36).toFixed(1)},${(margin.top + iH / 2).toFixed(1)})" font-size="11" fill="${textColor}">Density</text>`;
    const xLabel = `<text x="${(margin.left + iW / 2).toFixed(1)}" y="${(H - 4).toFixed(1)}" text-anchor="middle" font-size="11" fill="${textColor}">θ (probability of heads)</text>`;

    const ci = makeCI(alphaN, betaN, yMax, colors.post);
    const priorPath = makePath(priorY, yMax, colors.prior, 1.5, 0.07);
    const likePath = makePath(likeYScaled, yMax, colors.like, 1.5, 0.07);
    const postPath = makePath(postY, yMax, colors.post, 2.5, 0.14);

    const legend = [
      { color: colors.prior, label: `Prior Beta(${alpha0}, ${beta0})` },
      { color: colors.like, label: h + t > 0 ? `Likelihood (${h}H, ${t}T)` : 'Likelihood (no data)' },
      { color: colors.post, label: `Posterior Beta(${alphaN}, ${betaN})` },
    ].map((item, i) =>
      `<rect x="${margin.left + iW - 185}" y="${margin.top + 6 + i * 18}" width="11" height="11" rx="2" fill="${item.color}" fill-opacity="0.8"/>` +
      `<text x="${margin.left + iW - 169}" y="${margin.top + 16 + i * 18}" font-size="10.5" fill="${textColor}">${item.label}</text>`
    ).join('');

    svg.innerHTML = xAxis + yAxis + xTicksSVG + yLabel + xLabel + ci + priorPath + likePath + postPath + legend;

    const postMean = betaMean(alphaN, betaN);
    const postMode = betaMode(alphaN, betaN);
    const postStd = Math.sqrt(betaVariance(alphaN, betaN));
    const ci95lo = betaQuantile(0.025, alphaN, betaN);
    const ci95hi = betaQuantile(0.975, alphaN, betaN);

    statsDiv.innerHTML = [
      { label: 'Posterior Mean', value: postMean.toFixed(4) },
      { label: 'Posterior Mode', value: postMode !== null ? postMode.toFixed(4) : '—' },
      { label: 'Posterior Std', value: postStd.toFixed(4) },
      { label: '95% CI', value: `[${ci95lo.toFixed(3)}, ${ci95hi.toFixed(3)}]` },
      { label: 'αₙ / βₙ', value: `${alphaN} / ${betaN}` },
    ].map(s =>
      `<div class="chart-stat"><span class="chart-stat__label">${s.label}</span><span class="chart-stat__value">${s.value}</span></div>`
    ).join('');
  }

  function bindSlider(id, displayId, decimals = 0) {
    const el = document.getElementById(id);
    const disp = document.getElementById(displayId);
    el.addEventListener('input', () => {
      disp.textContent = parseFloat(el.value).toFixed(decimals);
      render();
    });
  }

  bindSlider('alpha-prior', 'alpha-val');
  bindSlider('beta-prior', 'beta-val');
  bindSlider('heads-obs', 'heads-val');
  bindSlider('tails-obs', 'tails-val');

  new MutationObserver(render).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  render();
})();
</script>
