---
// PowerCalculator — A/B test power & sample size calculator
// Two-sided test: both rejection tails are shaded
---

<div class="interactive-chart" id="power-calc">
  <div class="interactive-chart__header">Interactive — Power & Sample Size Calculator</div>
  <div class="interactive-chart__canvas">
    <svg id="power-svg" width="100%" viewBox="0 0 700 300" preserveAspectRatio="xMidYMid meet" aria-label="Power calculation distributions"></svg>
    <div id="power-stats" class="chart-stats-row"></div>
  </div>
  <div class="interactive-chart__controls">
    <div class="chart-control">
      <label for="pc-alpha">Significance α <span class="control-value" id="pc-alpha-val">0.05</span></label>
      <input type="range" id="pc-alpha" min="0.01" max="0.15" step="0.005" value="0.05" />
    </div>
    <div class="chart-control">
      <label for="pc-power">Power 1−β <span class="control-value" id="pc-power-val">0.80</span></label>
      <input type="range" id="pc-power" min="0.50" max="0.99" step="0.01" value="0.80" />
    </div>
    <div class="chart-control">
      <label for="pc-mde">MDE (absolute) <span class="control-value" id="pc-mde-val">0.02</span></label>
      <input type="range" id="pc-mde" min="0.005" max="0.10" step="0.005" value="0.02" />
    </div>
    <div class="chart-control">
      <label for="pc-sigma">Metric Std σ <span class="control-value" id="pc-sigma-val">0.10</span></label>
      <input type="range" id="pc-sigma" min="0.05" max="0.50" step="0.01" value="0.10" />
    </div>
  </div>
</div>

<script>
(function() {
  "use strict";

  function probit(p) {
    if (p <= 0) return -8;
    if (p >= 1) return 8;
    const a1 = 2.50662823884, a2 = -18.61500062529, a3 = 41.39119773534, a4 = -25.44106049637;
    const b1 = -8.47351093090, b2 = 23.08336743743, b3 = -21.06224101826, b4 = 3.13082909833;
    const c1 = 0.3374754822726147, c2 = 0.9761690190917186, c3 = 0.1607979714918209;
    const c4 = 0.0276438810333863, c5 = 0.0038405729373609, c6 = 0.0003951896511349;
    const c7 = 0.0000321767881768, c8 = 0.0000002888167364, c9 = 0.0000003960315187;
    if (p >= 0.02425 && p <= 1 - 0.02425) {
      const q = p - 0.5;
      const r = q * q;
      return (((((a4 * r + a3) * r + a2) * r + a1) * q)) / ((((b4 * r + b3) * r + b2) * r + b1) * r + 1);
    }
    const sign = p < 0.5 ? -1 : 1;
    const pp = p < 0.5 ? p : 1 - p;
    const q = Math.sqrt(-2 * Math.log(pp));
    return sign * ((((((((c9 * q + c8) * q + c7) * q + c6) * q + c5) * q + c4) * q + c3) * q + c2) * q + c1);
  }

  function normalPDF(x, mu, sigma) {
    const z = (x - mu) / sigma;
    return Math.exp(-0.5 * z * z) / (sigma * Math.sqrt(2 * Math.PI));
  }

  function linspace(a, b, n) {
    return Array.from({ length: n }, (_, i) => a + (b - a) * i / (n - 1));
  }

  const svg = document.getElementById('power-svg');
  const statsDiv = document.getElementById('power-stats');
  const margin = { top: 20, right: 20, bottom: 40, left: 44 };
  const W = 700, H = 300;
  const iW = W - margin.left - margin.right, iH = H - margin.top - margin.bottom;
  const N = 400;

  function render() {
    const alpha = parseFloat(document.getElementById('pc-alpha').value);
    const power = parseFloat(document.getElementById('pc-power').value);
    const mde = parseFloat(document.getElementById('pc-mde').value);
    const sigma = parseFloat(document.getElementById('pc-sigma').value);

    const z_a = probit(1 - alpha / 2);
    const z_b = probit(power);
    const n = Math.ceil(2 * sigma * sigma * (z_a + z_b) * (z_a + z_b) / (mde * mde));
    const se = sigma * Math.sqrt(2 / n);

    const muNull = 0, muAlt = mde;
    const critRight = z_a * se;
    const critLeft = -z_a * se;

    const padding = 4.5 * se;
    const xMin = Math.min(muNull - padding, muAlt - padding);
    const xMax = Math.max(muNull + padding, muAlt + padding);
    const xs = linspace(xMin, xMax, N);

    const nullY = xs.map(x => normalPDF(x, muNull, se));
    const altY = xs.map(x => normalPDF(x, muAlt, se));
    const yMax = Math.max(...nullY, ...altY) * 1.15;

    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const textColor = isDark ? '#a1a1aa' : '#71717a';
    const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
    const axisColor = isDark ? '#262626' : '#e4e4e7';
    const accentColor = isDark ? '#818cf8' : '#6366f1';

    function xScale(v) { return margin.left + (v - xMin) / (xMax - xMin) * iW; }
    function yScale(v) { return margin.top + iH - (v / yMax) * iH; }

    function areaPath(ys, lo, hi, color, opacity) {
      const pts = xs.map((x, i) => ({ x, y: ys[i] })).filter(d => d.x >= lo && d.x <= hi);
      if (pts.length < 2) return '';
      const path = pts.map(d => `${xScale(d.x).toFixed(2)},${yScale(d.y).toFixed(2)}`).join(' L ');
      const bot = yScale(0).toFixed(2);
      return `<path d="M ${xScale(pts[0].x).toFixed(2)},${bot} L ${path} L ${xScale(pts[pts.length - 1].x).toFixed(2)},${bot} Z" fill="${color}" fill-opacity="${opacity}" stroke="none"/>`;
    }

    function linePath(ys, color, sw) {
      const pts = xs.map((x, i) => `${xScale(x).toFixed(2)},${yScale(ys[i]).toFixed(2)}`).join(' L ');
      return `<path d="M ${pts}" stroke="${color}" stroke-width="${sw}" fill="none" vector-effect="non-scaling-stroke"/>`;
    }

    // Both tails of the null distribution (two-sided α)
    const typeI_right = areaPath(nullY, critRight, xMax + 1, '#ef4444', 0.4);
    const typeI_left = areaPath(nullY, xMin - 1, critLeft, '#ef4444', 0.4);
    
    // Type II error: failing to reject H0 when Ha is true (between critLeft and critRight)
    const typeII = areaPath(altY, critLeft, critRight, '#f59e0b', 0.35);
    
    // Power: correctly rejecting H0 when Ha is true (outside critLeft and critRight)
    const powerArea_right = areaPath(altY, critRight, xMax + 1, '#22c55e', 0.3);
    const powerArea_left = areaPath(altY, xMin - 1, critLeft, '#22c55e', 0.3);

    const nullPath = linePath(nullY, isDark ? '#94a3b8' : '#64748b', 2);
    const altPath = linePath(altY, accentColor, 2.5);

    const critLineR = `<line x1="${xScale(critRight).toFixed(1)}" y1="${margin.top}" x2="${xScale(critRight).toFixed(1)}" y2="${(margin.top + iH).toFixed(1)}" stroke="${isDark ? '#555' : '#999'}" stroke-width="1.5" stroke-dasharray="5,3"/>`;
    const critLineL = `<line x1="${xScale(critLeft).toFixed(1)}" y1="${margin.top}" x2="${xScale(critLeft).toFixed(1)}" y2="${(margin.top + iH).toFixed(1)}" stroke="${isDark ? '#555' : '#999'}" stroke-width="1.5" stroke-dasharray="5,3"/>`;

    const xAxis = `<line x1="${margin.left}" y1="${margin.top + iH}" x2="${margin.left + iW}" y2="${margin.top + iH}" stroke="${axisColor}" stroke-width="1.5"/>`;
    const yAxis = `<line x1="${margin.left}" y1="${margin.top}" x2="${margin.left}" y2="${margin.top + iH}" stroke="${axisColor}" stroke-width="1.5"/>`;

    const xTicks = linspace(xMin, xMax, 7);
    const xTicksSVG = xTicks.map(v =>
      `<text x="${xScale(v).toFixed(1)}" y="${(margin.top + iH + 16).toFixed(1)}" text-anchor="middle" font-size="10" fill="${textColor}">${(v / se).toFixed(1)}σ</text>` +
      `<line x1="${xScale(v).toFixed(1)}" y1="${margin.top}" x2="${xScale(v).toFixed(1)}" y2="${(margin.top + iH).toFixed(1)}" stroke="${gridColor}" stroke-dasharray="3,3"/>`
    ).join('');

    const h0Label = `<text x="${xScale(muNull).toFixed(1)}" y="${(margin.top + 14).toFixed(1)}" text-anchor="middle" font-size="11" fill="${textColor}" font-weight="600">H₀</text>`;
    const haLabel = `<text x="${xScale(muAlt).toFixed(1)}" y="${(margin.top + 14).toFixed(1)}" text-anchor="middle" font-size="11" fill="${accentColor}" font-weight="600">Hₐ</text>`;

    const legend = [
      { color: '#ef4444', opacity: 0.6, label: `α = ${alpha.toFixed(3)} (Type I, both tails)` },
      { color: '#f59e0b', opacity: 0.6, label: `β = ${(1 - power).toFixed(3)} (Type II)` },
      { color: '#22c55e', opacity: 0.5, label: `Power = ${power.toFixed(2)}` },
    ].map((item, i) =>
      `<rect x="${margin.left + iW - 195}" y="${margin.top + 24 + i * 18}" width="11" height="11" rx="2" fill="${item.color}" fill-opacity="${item.opacity}"/>` +
      `<text x="${margin.left + iW - 178}" y="${margin.top + 33 + i * 18}" font-size="10.5" fill="${textColor}">${item.label}</text>`
    ).join('');

    svg.innerHTML = xTicksSVG + typeI_right + typeI_left + typeII + powerArea_right + powerArea_left + nullPath + altPath + critLineR + critLineL + xAxis + yAxis + h0Label + haLabel + legend;

    statsDiv.innerHTML = [
      { label: 'n per variant', value: n.toLocaleString() },
      { label: 'Total n', value: (n * 2).toLocaleString() },
      { label: 'Critical value', value: `±${z_a.toFixed(3)} SE` },
      { label: 'Standard Error', value: se.toFixed(4) },
      { label: 'Z_α/2', value: z_a.toFixed(3) },
      { label: 'Z_β', value: z_b.toFixed(3) },
    ].map(s =>
      `<div class="chart-stat"><span class="chart-stat__label">${s.label}</span><span class="chart-stat__value">${s.value}</span></div>`
    ).join('');
  }

  function bindSlider(id, displayId, decimals) {
    const el = document.getElementById(id);
    const disp = document.getElementById(displayId);
    el.addEventListener('input', () => {
      disp.textContent = parseFloat(el.value).toFixed(decimals);
      render();
    });
  }

  bindSlider('pc-alpha', 'pc-alpha-val', 3);
  bindSlider('pc-power', 'pc-power-val', 2);
  bindSlider('pc-mde', 'pc-mde-val', 3);
  bindSlider('pc-sigma', 'pc-sigma-val', 2);

  new MutationObserver(render).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  render();
})();
</script>
